#!/usr/bin/env bash
# Extract one task's full text from a Wyvrn plan file (.claude-wyvrn-local/plans/)
# into a file the implementer subagent reads in one call, so the task text never
# has to be pasted through the orchestrator's context.
#
# Usage: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]
# Default OUTFILE: <repo-root>/.claude-wyvrn-local/sdd/task-<N>-brief.md
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]" >&2
  exit 2
fi

plan=$1
n=$2
[ -f "$plan" ] || { echo "no such plan file: $plan" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$(bash "$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/task-${n}-brief.md"
fi

# A task ends at the next heading of the same or shallower level -- the next
# task, or a trailing plan section such as "## Final verification". Stopping
# only at the next Task heading would append every trailing section to the last
# task's brief, handing its implementer the plan-level full-suite step.
awk -v n="$n" '
  /^```/ { infence = !infence }
  !infence && /^#+[ \t]/ {
    match($0, /^#+/)
    lvl = RLENGTH
    if ($0 ~ ("^#+[ \t]+Task[ \t]+" n "([^0-9]|$)")) {
      intask = 1
      tasklvl = lvl
    } else if (intask && lvl <= tasklvl) {
      intask = 0
    }
  }
  intask { print }
' "$plan" > "$out"

if [ ! -s "$out" ]; then
  echo "task ${n} not found in ${plan} (no heading matching 'Task ${n}')" >&2
  exit 3
fi

echo "wrote ${out}: $(wc -l < "$out" | tr -d ' ') lines"
